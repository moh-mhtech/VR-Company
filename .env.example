# OpenAI-compatible model access (required to run agents)
OPENAI_API_KEY=sk-your-key-here
# Default: gpt-5.4-mini — free daily quota with traffic sharing (2.5M tokens/day
# on mini/nano). Use gpt-5.4-nano to stretch further; gpt-5.4 only if you need
# higher quality (250k free tokens/day on the full-model pool).
OPENAI_MODEL=gpt-5.4-mini

# Optional: AgentOps live session visualization (https://app.agentops.ai)
# Create a project/API key, then uncomment and set:
# AGENTOPS_API_KEY=your-agentops-key-here

# Optional: override runtime TCP endpoint (defaults come from runtime/limits.yaml)
# VR_RUNTIME_HOST=127.0.0.1
# VR_RUNTIME_PORT=8765
